{
  "name": "huangdi-calendar",
  "version": "0.10.07",
  "description": "古历法 - 融合中华传统历法、节气物候、黄帝纪元、圣太一天历与玛雅历法的跨平台时间系统。",
  "license": "MIT",
  "author": "sanbyzhu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanbyzhu/huangdi-calendar.git"
  },
  "bugs": {
    "url": "https://github.com/sanbyzhu/huangdi-calendar/issues"
  },
  "homepage": "https://github.com/sanbyzhu/huangdi-calendar#readme",
  "keywords": [
    "calendar",
    "huangdi",
    "lunar-calendar",
    "solar-terms",
    "mayan-calendar",
    "react",
    "capacitor",
    "electron"
  ],
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "lunar-javascript": "^1.7.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "build": {
    "appId": "com.huangdi.calendar.desktop",
    "productName": "古历法",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "public/assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "zip",
        "nsis"
      ],
      "icon": "assets/dragon_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
